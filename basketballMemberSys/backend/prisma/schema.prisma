// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  email         String?  @unique
  password      String
  name          String
  phoneNumber   String?
  role          String   @default("PARENT") // PARENT, COACH, ADMIN
  points        Int      @default(0)
  level         String   @default("NOVICE") // NOVICE, EXPERT
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  children      Child[]
  registrations Registration[]
  transactions  PointTransaction[]
}

model Child {
  id            Int      @id @default(autoincrement())
  name          String
  ageGroup      String   // e.g., U10, U12, U14
  skillLevel    String   @default("BEGINNER")
  parentId      Int
  parent        User     @relation(fields: [parentId], references: [id])
  registrations Registration[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Activity {
  id            Int      @id @default(autoincrement())
  title         String
  type          String   // COMPETITION, TRAINING, SPECIAL_EVENT, COURSE
  description   String?
  date          String   // YYYY-MM-DD format
  time          String   // HH:MM format
  location      String
  price         Float    @default(0)
  dateTime      DateTime
  maxParticipants Int
  currentParticipants Int @default(0)
  registrations Registration[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Registration {
  id                Int      @id @default(autoincrement())
  userId            Int
  user              User     @relation(fields: [userId], references: [id])
  childId           Int
  child             Child    @relation(fields: [childId], references: [id])
  activityId        Int
  activity          Activity @relation(fields: [activityId], references: [id])
  medicalStatement  String?  // File path
  emergencyContact  String?
  emergencyPhone    String?
  status            String   @default("CONFIRMED") // PENDING, CONFIRMED, CANCELLED
  attendance        Boolean  @default(false)
  createdAt         DateTime @default(now())
}

model Reward {
  id            Int      @id @default(autoincrement())
  title         String
  description   String?
  pointsRequired Int
  stock         Int      @default(0)
  imageUrl      String?
  createdAt     DateTime @default(now())
}

model PointTransaction {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  points        Int      // Positive for earn, negative for spend
  reason        String   // ATTENDANCE, WIN, REDEMPTION
  createdAt     DateTime @default(now())
}
